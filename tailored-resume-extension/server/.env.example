# ============================================
# Agentex Server — Environment Configuration
# ============================================
# Copy this file to .env and customize for your setup.
# DO NOT commit .env to git.

# Server
NODE_ENV=production
PORT=3000

# CORS — Comma-separated list of allowed origins
# Add your Chrome extension ID and any frontend URLs
ALLOWED_ORIGINS=chrome-extension://YOUR_EXTENSION_ID_HERE,https://your-domain.com

# LaTeX
MAX_LATEX_SIZE=500000
MAX_BODY_SIZE=2mb

# Rate Limiting
# Window in milliseconds, max requests per window per IP
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=30

# File cleanup interval (ms)
CLEANUP_INTERVAL=300000

# Temp directory
TMP_DIR=/tmp/agentex
